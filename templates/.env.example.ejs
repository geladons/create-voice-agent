# ─── LiveKit Credentials ─────────────────────────────────────────────
# Generate a key/secret pair or use defaults for local development.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

<% if (llmProvider === 'openai') { -%>
# ─── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
<% } else if (deploymentType === 'standalone') { -%>
# ─── Ollama (Standalone Docker) ─────────────────────────────────────
# The agent connects to the Ollama container via Docker networking.
# No need to change this — it is set automatically in docker-compose.yml.
OLLAMA_BASE_URL=http://localhost:11434
<% } else { -%>
# ─── Ollama (Existing Host) ─────────────────────────────────────────
# Points to the host machine's Ollama instance from inside Docker.
<% if (ollamaIp === 'localhost' || ollamaIp === '127.0.0.1') { -%>
OLLAMA_BASE_URL=http://host.docker.internal:11434
<% } else { -%>
OLLAMA_BASE_URL=http://<%= ollamaIp %>:11434
<% } -%>
<% } -%>

# ─── LiveKit Agent Runtime ───────────────────────────────────────────
# Raise defaults for offline STT/TTS workloads.
LIVEKIT_JOB_MEMORY_WARN_MB=1024
LIVEKIT_JOB_MEMORY_LIMIT_MB=1536

<% if (llmProvider === 'ollama') { -%>
# ─── Ollama LLM Timeout ─────────────────────────────────────────────
# Increase when first token is delayed by model loading.
OLLAMA_LLM_TIMEOUT_SEC=120
# Wait for the initial Web UI settings packet before session start.
INITIAL_SETTINGS_WAIT_SEC=3
# Warm model weights on startup (1=enabled, 0=disabled).
OLLAMA_WARMUP=1

# ─── Piper / ONNX Runtime ────────────────────────────────────────────
# Explicit thread counts prevent ONNX Runtime from setting CPU affinity in Docker.
PIPER_ORT_INTRA_THREADS=1
PIPER_ORT_INTER_THREADS=1

# ─── Faster-Whisper / HuggingFace Cache ──────────────────────────────
# Keep models cached locally to reduce repeated Hub requests.
FASTER_WHISPER_MODEL_CACHE_DIR=/app/models/faster-whisper
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=1
FASTER_WHISPER_BEST_OF=1
FASTER_WHISPER_VAD_FILTER=1
# Force fully offline loading (set to 1 for air-gapped operation).
FASTER_WHISPER_LOCAL_FILES_ONLY=1
HF_HOME=/app/.cache/huggingface
HUGGINGFACE_HUB_CACHE=/app/.cache/huggingface/hub
<% } -%>
