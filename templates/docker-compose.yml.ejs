version: "3.9"

services:
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
  # ─── Ollama (Standalone) ─────────────────────────────────────────
  ollama:
    image: ollama/ollama
    restart: unless-stopped
    ports:
      - "11434:11434"
    environment:
      - OLLAMA_ORIGINS="*"
    volumes:
      - ollama_data:/root/.ollama
    healthcheck:
      test: ["CMD", "ollama", "list"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 10s
    deploy:
      resources:
        limits:
          cpus: '<%= cpuLimit %>'

  # ─── Model Auto-Puller ───────────────────────────────────────────
  ollama-pull:
    image: curlimages/curl:latest
    restart: "no"
    depends_on:
      ollama:
        condition: service_healthy
    command:
      - sh
      - -c
      - |
        set -e
        echo "Pulling model <%= modelName %>..."
        curl -sS -X POST http://ollama:11434/api/pull \
          -H "Content-Type: application/json" \
          -d '{"name":"<%= modelName %>","stream":false}'
        echo "Model pulled successfully."

<% } -%>
  # ─── Redis (required by LiveKit) ───────────────────────────────────
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5

  # ─── LiveKit Server ────────────────────────────────────────────────
  livekit:
    image: livekit/livekit-server:latest
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
    ports:
      - "7880:7880"
      - "7881:7881"
      - "50000-50050:50000-50050/udp"
    environment:
      - "LIVEKIT_KEYS=${LIVEKIT_API_KEY}: ${LIVEKIT_API_SECRET}"
      - "NODE_IP=<%= hostIp %>"
      - "UDP_PORT=50000-50050"
      - "REDIS_HOST=redis:6379"
    command: >
      --bind 0.0.0.0
      --dev

  # ─── Python Voice Agent ────────────────────────────────────────────
  agent:
    build:
      context: ./python-agent
      dockerfile: Dockerfile
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
      livekit:
        condition: service_started
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
      ollama:
        condition: service_healthy
      ollama-pull:
        condition: service_completed_successfully
<% } -%>
    environment:
      - LIVEKIT_URL=ws://livekit:7880
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}
      - LIVEKIT_JOB_MEMORY_WARN_MB=${LIVEKIT_JOB_MEMORY_WARN_MB:-1024}
      - LIVEKIT_JOB_MEMORY_LIMIT_MB=${LIVEKIT_JOB_MEMORY_LIMIT_MB:-1536}
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
      - OLLAMA_BASE_URL=http://ollama:11434/v1
<% } else if (llmProvider === 'ollama' && deploymentType === 'existing') { -%>
      - OLLAMA_BASE_URL=${OLLAMA_BASE_URL:-http://host.docker.internal:11434/v1}
<% } else { -%>
      - OPENAI_API_KEY=${OPENAI_API_KEY}
<% } -%>
<% if (llmProvider === 'ollama') { -%>
      - PIPER_ORT_INTRA_THREADS=${PIPER_ORT_INTRA_THREADS:-1}
      - PIPER_ORT_INTER_THREADS=${PIPER_ORT_INTER_THREADS:-1}
      - FASTER_WHISPER_MODEL_CACHE_DIR=${FASTER_WHISPER_MODEL_CACHE_DIR:-/app/models/faster-whisper}
      - FASTER_WHISPER_LOCAL_FILES_ONLY=${FASTER_WHISPER_LOCAL_FILES_ONLY:-0}
      - HF_HOME=${HF_HOME:-/app/.cache/huggingface}
      - HUGGINGFACE_HUB_CACHE=${HUGGINGFACE_HUB_CACHE:-/app/.cache/huggingface/hub}
<% } -%>
<% if (llmProvider === 'ollama' && deploymentType === 'existing') { -%>
    extra_hosts:
      - "host.docker.internal:host-gateway"
<% } -%>

<% if (includeFrontend) { -%>
  # ─── Next.js Frontend ─────────────────────────────────────────────
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    restart: unless-stopped
    depends_on:
      - livekit
    ports:
      - "3000:3000"
    environment:
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}
      - LIVEKIT_URL=ws://livekit:7880
      - NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
      - OLLAMA_BASE_URL=http://ollama:11434
<% } else if (llmProvider === 'ollama') { -%>
      - OLLAMA_BASE_URL=http://host.docker.internal:11434
<% } -%>
<% } -%>

<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
volumes:
  ollama_data:
<% } -%>
