version: "3.9"

services:
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
  # ─── Ollama (Standalone) ─────────────────────────────────────────
  ollama:
    image: ollama/ollama
    restart: unless-stopped
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    deploy:
      resources:
        limits:
          cpus: '<%= cpuLimit %>'

<% } -%>
  # ─── Redis (required by LiveKit) ───────────────────────────────────
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5

  # ─── LiveKit Server ────────────────────────────────────────────────
  livekit:
    image: livekit/livekit-server:latest
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
    ports:
      - "7880:7880"
      - "7881:7881"
      - "50000-50050:50000-50050/udp"
    environment:
      - "LIVEKIT_KEYS=${LIVEKIT_API_KEY}: ${LIVEKIT_API_SECRET}"
      - "NODE_IP=<%= hostIp %>"
      - "UDP_PORT=50000-50050"
      - "REDIS_HOST=redis:6379"
    command: >
      --bind 0.0.0.0
      --dev

  # ─── Python Voice Agent ────────────────────────────────────────────
  agent:
    build:
      context: ./python-agent
      dockerfile: Dockerfile
    restart: unless-stopped
    depends_on:
      - livekit
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
      - ollama
<% } -%>
    environment:
      - LIVEKIT_URL=ws://livekit:7880
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}
<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
      - OLLAMA_BASE_URL=http://ollama:11434
<% } else if (llmProvider === 'ollama' && deploymentType === 'existing') { -%>
      - OLLAMA_BASE_URL=${OLLAMA_BASE_URL}
<% } else { -%>
      - OPENAI_API_KEY=${OPENAI_API_KEY}
<% } -%>
<% if (llmProvider === 'ollama' && deploymentType === 'existing') { -%>
    extra_hosts:
      - "host.docker.internal:host-gateway"
<% } -%>

<% if (includeFrontend) { -%>
  # ─── Next.js Frontend ─────────────────────────────────────────────
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    restart: unless-stopped
    depends_on:
      - livekit
    ports:
      - "3000:3000"
    environment:
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}
      - LIVEKIT_URL=ws://livekit:7880
      - NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
<% } -%>

<% if (llmProvider === 'ollama' && deploymentType === 'standalone') { -%>
volumes:
  ollama_data:
<% } -%>
