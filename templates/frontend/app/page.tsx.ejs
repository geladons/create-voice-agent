"use client";

import { useEffect, useMemo, useState, type Dispatch, type SetStateAction } from "react";
import {
  BarVisualizer,
  Chat,
  DisconnectButton,
  LiveKitRoom,
  RoomAudioRenderer,
  useRoomContext,
  useVoiceAssistant,
} from "@livekit/components-react";
import { ConnectionState, RoomEvent } from "livekit-client";
import "@livekit/components-styles";

type AgentSettings = {
  model: string;
  temperature: number;
  language: string;
};

type VoiceAssistantUIProps = {
  settings: AgentSettings;
  setSettings: Dispatch<SetStateAction<AgentSettings>>;
  availableModels: string[];
  onRoomStateChange: (state: ConnectionState) => void;
  onDisconnected: () => void;
};

function VoiceAssistantUI({
  settings,
  setSettings,
  availableModels,
  onRoomStateChange,
  onDisconnected,
}: VoiceAssistantUIProps) {
  const room = useRoomContext();
  const { state, audioTrack } = useVoiceAssistant();
  const [syncError, setSyncError] = useState<string | null>(null);

  const modelOptions = useMemo(
    () => Array.from(new Set([settings.model, ...availableModels])),
    [availableModels, settings.model]
  );

  useEffect(() => {
    const handleConnectionStateChanged = (nextState: ConnectionState) => {
      onRoomStateChange(nextState);
      if (nextState === ConnectionState.Disconnected) {
        onDisconnected();
      }
    };

    handleConnectionStateChanged(room.state);
    room.on(RoomEvent.ConnectionStateChanged, handleConnectionStateChanged);

    return () => {
      room.off(RoomEvent.ConnectionStateChanged, handleConnectionStateChanged);
    };
  }, [onDisconnected, onRoomStateChange, room]);

  useEffect(() => {
    if (room.state !== ConnectionState.Connected) {
      return;
    }

    const payload = new TextEncoder().encode(JSON.stringify(settings));

    room.localParticipant
      .publishData(payload, { reliable: true, topic: "agent-settings" })
      .then(() => setSyncError(null))
      .catch((err: unknown) => {
        setSyncError(err instanceof Error ? err.message : "Failed to sync settings");
      });
  }, [room, settings]);

  return (
    <div
      style={{
        display: "grid",
        gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
        gap: "1rem",
        padding: "1rem 0",
        textAlign: "left",
      }}
    >
      <section
        style={{
          border: "1px solid #e5e7eb",
          borderRadius: "12px",
          padding: "1rem",
          background: "#ffffff",
        }}
      >
        <h2 style={{ marginTop: 0, marginBottom: "0.5rem" }}>Voice + Text</h2>
        <p style={{ marginTop: 0, color: "#374151" }}>Agent State: {state}</p>
        <BarVisualizer
          state={state}
          barCount={5}
          trackRef={audioTrack}
          style={{ width: "100%", height: "80px" }}
        />
        <div
          style={{
            marginTop: "1rem",
            border: "1px solid #e5e7eb",
            borderRadius: "10px",
            overflow: "hidden",
            minHeight: "340px",
          }}
        >
          <Chat />
        </div>
      </section>

      <aside
        style={{
          border: "1px solid #e5e7eb",
          borderRadius: "12px",
          padding: "1rem",
          background: "#f8fafc",
          display: "flex",
          flexDirection: "column",
          gap: "1rem",
        }}
      >
        <h3 style={{ margin: 0 }}>Control Panel</h3>

        <div>
          <h4 style={{ margin: "0 0 0.5rem 0" }}>System Status</h4>
          <p style={{ margin: 0, color: "#374151" }}>Room State: {room.state}</p>
          <p style={{ margin: "0.4rem 0 0 0", color: "#374151" }}>Agent State: {state}</p>
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: "0.75rem" }}>
          <h4 style={{ margin: 0 }}>Model Settings</h4>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Temperature: {settings.temperature.toFixed(2)}</span>
            <input
              type="range"
              min="0"
              max="1"
              step="0.01"
              value={settings.temperature}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  temperature: Number(event.target.value),
                }))
              }
            />
          </label>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Select Model</span>
            <select
              value={settings.model}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  model: event.target.value,
                }))
              }
              style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            >
              {modelOptions.map((modelName) => (
                <option key={modelName} value={modelName}>
                  {modelName}
                </option>
              ))}
            </select>
          </label>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Language</span>
            <select
              value={settings.language}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  language: event.target.value,
                }))
              }
              style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            >
              <option value="en">EN</option>
              <option value="ru">RU</option>
              <option value="de">DE</option>
              <option value="fr">FR</option>
              <option value="es">ES</option>
            </select>
          </label>
          {syncError ? <p style={{ margin: 0, color: "#991b1b" }}>{syncError}</p> : null}
        </div>

        <DisconnectButton>Disconnect</DisconnectButton>
      </aside>
    </div>
  );
}

export default function Home() {
  const [token, setToken] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [connected, setConnected] = useState(false);
  const [roomState, setRoomState] = useState<ConnectionState>(ConnectionState.Disconnected);
  const [serverUrl, setServerUrl] = useState("");
  const [showSecurityWarning, setShowSecurityWarning] = useState(false);
  const [settings, setSettings] = useState<AgentSettings>({
    model: "<%= modelName %>",
    temperature: 0.7,
    language: "<%= language %>",
  });
  const [availableModels, setAvailableModels] = useState<string[]>(["<%= modelName %>"]);

  const fallbackModels = useMemo(
    () => ["<%= modelName %>", "qwen3-vl:2b", "qwen3-vl:4b", "llama3.2:3b"],
    []
  );

  useEffect(() => {
    if (typeof window !== "undefined") {
      let envUrl = process.env.NEXT_PUBLIC_LIVEKIT_URL;
      if (!envUrl || envUrl.includes("127.0.0.1") || envUrl.includes("localhost")) {
        const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
        envUrl = `${protocol}//${window.location.hostname}:7880`;
      }
      setServerUrl(envUrl);
      setShowSecurityWarning(!Boolean(window.navigator.mediaDevices?.getUserMedia));
    }
  }, []);

  useEffect(() => {
    async function fetchToken() {
      try {
        const res = await fetch("/api/token?room=voice-room&username=user");
        if (!res.ok) throw new Error("Failed to fetch token");
        const data = await res.json();
        setToken(data.token);
      } catch (err: unknown) {
        setError(err instanceof Error ? err.message : "Unknown error");
      }
    }
    fetchToken();
  }, []);

  useEffect(() => {
    let isCancelled = false;

    async function loadModels() {
      try {
        const res = await fetch("/api/models");
        if (!res.ok) throw new Error("Failed to fetch model list");
        const data = await res.json();
        const models = Array.isArray(data.models)
          ? data.models.filter((item: unknown): item is string => typeof item === "string")
          : [];

        if (!isCancelled && models.length > 0) {
          setAvailableModels(Array.from(new Set([...models, ...fallbackModels])));
          return;
        }
      } catch {
        // Fall back to defaults if dynamic discovery fails.
      }

      if (!isCancelled) {
        setAvailableModels(fallbackModels);
      }
    }

    loadModels();
    return () => {
      isCancelled = true;
    };
  }, [fallbackModels]);

  useEffect(() => {
    setAvailableModels((current) =>
      Array.from(new Set([settings.model, ...current, ...fallbackModels]))
    );
  }, [fallbackModels, settings.model]);

  useEffect(() => {
    if (roomState === ConnectionState.Disconnected) {
      setConnected(false);
    }
  }, [roomState]);

  const securityBanner = showSecurityWarning ? (
    <div
      style={{
        background: "#fee2e2",
        border: "1px solid #ef4444",
        color: "#991b1b",
        borderRadius: "10px",
        padding: "0.85rem 1rem",
        marginBottom: "1rem",
        fontWeight: 600,
      }}
    >
      ⚠️ Security Warning: microphone access is blocked because `navigator.mediaDevices` is not
      available. Use HTTPS, Ngrok, or allow insecure origins for local testing.
    </div>
  ) : null;

  if (error) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        {securityBanner}
        <h1>Error</h1>
        <p>{error}</p>
      </div>
    );
  }

  if (!token) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        {securityBanner}
        <p>Connecting to voice agent...</p>
      </div>
    );
  }

  return (
    <main style={{ padding: "2rem", textAlign: "center", maxWidth: "1200px", margin: "0 auto" }}>
      <h1><%= projectName %></h1>
      {securityBanner}
      {(!connected || roomState === ConnectionState.Disconnected) && (
        <button
          type="button"
          onClick={() => setConnected(true)}
          disabled={!serverUrl}
          style={{ padding: "0.75rem 1.25rem", marginBottom: "1rem" }}
        >
          Start Conversation
        </button>
      )}
      {serverUrl ? (
        <LiveKitRoom serverUrl={serverUrl} token={token} connect={connected} audio={true}>
          <VoiceAssistantUI
            settings={settings}
            setSettings={setSettings}
            availableModels={availableModels}
            onRoomStateChange={setRoomState}
            onDisconnected={() => {
              setConnected(false);
              setRoomState(ConnectionState.Disconnected);
            }}
          />
          <RoomAudioRenderer />
        </LiveKitRoom>
      ) : (
        <p>Detecting LiveKit server URL...</p>
      )}
      <p style={{ color: "#475569", marginTop: "0.75rem" }}>Connection State: {roomState}</p>
    </main>
  );
}
