"use client";

import { useEffect, useState } from "react";
import {
  LiveKitRoom,
  RoomAudioRenderer,
  useVoiceAssistant,
  BarVisualizer,
  Chat,
  DisconnectButton,
} from "@livekit/components-react";
import "@livekit/components-styles";

function VoiceAssistantUI() {
  const { state, audioTrack } = useVoiceAssistant();
  const [temperature, setTemperature] = useState(0.7);
  const [selectedModel, setSelectedModel] = useState("<%= modelName %>");

  return (
    <div
      style={{
        display: "grid",
        gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
        gap: "1rem",
        padding: "1rem 0",
        textAlign: "left",
      }}
    >
      <section
        style={{
          border: "1px solid #e5e7eb",
          borderRadius: "12px",
          padding: "1rem",
          background: "#ffffff",
        }}
      >
        <h2 style={{ marginTop: 0, marginBottom: "0.5rem" }}>Voice + Text</h2>
        <p style={{ marginTop: 0, color: "#374151" }}>Agent Status: {state}</p>
        <BarVisualizer
          state={state}
          barCount={5}
          trackRef={audioTrack}
          style={{ width: "100%", height: "80px" }}
        />
        <div
          style={{
            marginTop: "1rem",
            border: "1px solid #e5e7eb",
            borderRadius: "10px",
            overflow: "hidden",
            minHeight: "340px",
          }}
        >
          <Chat />
        </div>
      </section>

      <aside
        style={{
          border: "1px solid #e5e7eb",
          borderRadius: "12px",
          padding: "1rem",
          background: "#f8fafc",
          display: "flex",
          flexDirection: "column",
          gap: "1rem",
        }}
      >
        <h3 style={{ margin: 0 }}>Control Panel</h3>

        <div>
          <h4 style={{ margin: "0 0 0.5rem 0" }}>System Status</h4>
          <p style={{ margin: 0, color: "#374151" }}>Connection State: {state}</p>
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: "0.75rem" }}>
          <h4 style={{ margin: 0 }}>Model Settings</h4>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Temperature: {temperature.toFixed(2)}</span>
            <input
              type="range"
              min="0"
              max="1"
              step="0.01"
              value={temperature}
              onChange={(event) => setTemperature(Number(event.target.value))}
            />
          </label>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Select Model</span>
            <select
              value={selectedModel}
              onChange={(event) => setSelectedModel(event.target.value)}
              style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            >
              <option value="<%= modelName %>"><%= modelName %></option>
              <option value="qwen3-vl:2b">qwen3-vl:2b (Fastest)</option>
              <option value="llama3.2:3b">llama3.2:3b (Smart)</option>
            </select>
          </label>
        </div>

        <DisconnectButton>Disconnect</DisconnectButton>
      </aside>
    </div>
  );
}

export default function Home() {
  const [token, setToken] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [connected, setConnected] = useState(false);
  const [serverUrl, setServerUrl] = useState("");
  const [showSecurityWarning, setShowSecurityWarning] = useState(false);

  useEffect(() => {
    if (typeof window !== "undefined") {
      let envUrl = process.env.NEXT_PUBLIC_LIVEKIT_URL;
      // Aggressively override if the baked-in variable is empty, localhost, or 127.0.0.1
      if (!envUrl || envUrl.includes("127.0.0.1") || envUrl.includes("localhost")) {
        const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
        envUrl = `${protocol}//${window.location.hostname}:7880`;
      }
      setServerUrl(envUrl);

      const isInsecureRemoteHost =
        window.location.protocol === "http:" &&
        window.location.hostname !== "localhost" &&
        window.location.hostname !== "127.0.0.1";
      setShowSecurityWarning(isInsecureRemoteHost);
    }
  }, []);

  useEffect(() => {
    async function fetchToken() {
      try {
        const res = await fetch("/api/token?room=voice-room&username=user");
        if (!res.ok) throw new Error("Failed to fetch token");
        const data = await res.json();
        setToken(data.token);
      } catch (err: unknown) {
        setError(err instanceof Error ? err.message : "Unknown error");
      }
    }
    fetchToken();
  }, []);

  const securityBanner = showSecurityWarning ? (
    <div
      style={{
        background: "#fee2e2",
        border: "1px solid #ef4444",
        color: "#991b1b",
        borderRadius: "10px",
        padding: "0.85rem 1rem",
        marginBottom: "1rem",
        fontWeight: 600,
      }}
    >
      ⚠️ Microphone access is blocked by browsers over HTTP on remote IPs. Use HTTPS, Ngrok,
      or enable 'Insecure origins treated as secure' in chrome://flags.
    </div>
  ) : null;

  if (error) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        {securityBanner}
        <h1>Error</h1>
        <p>{error}</p>
      </div>
    );
  }

  if (!token) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        {securityBanner}
        <p>Connecting to voice agent...</p>
      </div>
    );
  }

  return (
    <main style={{ padding: "2rem", textAlign: "center", maxWidth: "1200px", margin: "0 auto" }}>
      <h1><%= projectName %></h1>
      {securityBanner}
      {!connected && (
        <button
          type="button"
          onClick={() => setConnected(true)}
          disabled={!serverUrl}
          style={{ padding: "0.75rem 1.25rem", marginBottom: "1rem" }}
        >
          Start Conversation
        </button>
      )}
      {serverUrl ? (
        <LiveKitRoom
          serverUrl={serverUrl}
          token={token}
          connect={connected}
          audio={true}
        >
          <VoiceAssistantUI />
          <RoomAudioRenderer />
        </LiveKitRoom>
      ) : (
        <p>Detecting LiveKit server URL...</p>
      )}
    </main>
  );
}
