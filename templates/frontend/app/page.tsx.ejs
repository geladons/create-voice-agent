"use client";

import {
  useCallback,
  useEffect,
  useMemo,
  useState,
  type Dispatch,
  type SetStateAction,
} from "react";
import {
  BarVisualizer,
  Chat,
  DisconnectButton,
  LiveKitRoom,
  RoomAudioRenderer,
  useRoomContext,
  useVoiceAssistant,
} from "@livekit/components-react";
import { ConnectionState, RoomEvent } from "livekit-client";
import "@livekit/components-styles";

type ConnectionStatus = "idle" | "connecting" | "connected" | "error";
type ServiceStatus = "online" | "offline" | "checking";

type AgentSettings = {
  model: string;
  temperature: number;
  top_p: number;
  top_k: number;
  max_tokens: number;
  reasoning_mode: boolean;
  language: string;
};

type ServiceHealth = {
  ollama: ServiceStatus;
  livekit: ServiceStatus;
  agent: ServiceStatus;
};

type VoiceAssistantUIProps = {
  settings: AgentSettings;
  setSettings: Dispatch<SetStateAction<AgentSettings>>;
  availableModels: string[];
  serviceHealth: ServiceHealth;
  onRoomStateChange: (state: ConnectionState) => void;
  onDisconnected: () => void;
  onAgentHeartbeat: () => void;
};

const DEFAULT_SETTINGS: AgentSettings = {
  model: "<%= modelName %>",
  temperature: 0.7,
  top_p: 0.9,
  top_k: 40,
  max_tokens: 512,
  reasoning_mode: false,
  language: "<%= language %>",
};

function statusColor(status: ServiceStatus) {
  if (status === "online") return "#16a34a";
  if (status === "checking") return "#f59e0b";
  return "#dc2626";
}

function VoiceAssistantUI({
  settings,
  setSettings,
  availableModels,
  serviceHealth,
  onRoomStateChange,
  onDisconnected,
  onAgentHeartbeat,
}: VoiceAssistantUIProps) {
  const room = useRoomContext();
  const { state, audioTrack } = useVoiceAssistant();
  const [syncError, setSyncError] = useState<string | null>(null);

  const modelOptions = useMemo(
    () => Array.from(new Set([settings.model, ...availableModels])),
    [availableModels, settings.model]
  );

  useEffect(() => {
    const handleConnectionStateChanged = (nextState: ConnectionState) => {
      onRoomStateChange(nextState);
      if (nextState === ConnectionState.Disconnected) {
        onDisconnected();
      }
    };

    const handleDataReceived = (payload: Uint8Array) => {
      try {
        const parsed = JSON.parse(new TextDecoder().decode(payload));
        if (parsed && parsed.type === "heartbeat") {
          onAgentHeartbeat();
        }
      } catch {
        // Ignore non-JSON or unrelated payloads.
      }
    };

    handleConnectionStateChanged(room.state);
    room.on(RoomEvent.ConnectionStateChanged, handleConnectionStateChanged);
    room.on(RoomEvent.DataReceived, handleDataReceived);

    return () => {
      room.off(RoomEvent.ConnectionStateChanged, handleConnectionStateChanged);
      room.off(RoomEvent.DataReceived, handleDataReceived);
    };
  }, [onAgentHeartbeat, onDisconnected, onRoomStateChange, room]);

  useEffect(() => {
    if (room.state !== ConnectionState.Connected) return;

    const payload = new TextEncoder().encode(JSON.stringify(settings));
    room.localParticipant
      .publishData(payload, { reliable: true, topic: "agent-settings" })
      .then(() => setSyncError(null))
      .catch((err: unknown) => {
        setSyncError(err instanceof Error ? err.message : "Failed to sync settings");
      });
  }, [room, settings]);

  return (
    <div
      style={{
        display: "grid",
        gridTemplateColumns: "minmax(0, 1fr) 340px",
        gap: "1rem",
        alignItems: "start",
        textAlign: "left",
      }}
    >
      <section
        style={{
          border: "1px solid #e5e7eb",
          borderRadius: "12px",
          padding: "1rem",
          background: "#ffffff",
        }}
      >
        <h2 style={{ marginTop: 0, marginBottom: "0.5rem" }}>Voice + Text Workspace</h2>
        <p style={{ marginTop: 0, color: "#374151" }}>Agent State: {state}</p>
        <BarVisualizer
          state={state}
          barCount={8}
          trackRef={audioTrack}
          style={{ width: "100%", height: "90px" }}
        />
        <div
          style={{
            marginTop: "1rem",
            border: "1px solid #e5e7eb",
            borderRadius: "10px",
            overflow: "hidden",
            minHeight: "380px",
          }}
        >
          <Chat />
        </div>
      </section>

      <aside
        style={{
          border: "1px solid #dbeafe",
          borderRadius: "12px",
          padding: "1rem",
          background: "#f8fafc",
          display: "flex",
          flexDirection: "column",
          gap: "1rem",
        }}
      >
        <h3 style={{ margin: 0 }}>Control Center</h3>

        <section>
          <h4 style={{ margin: "0 0 0.6rem 0" }}>Service Health</h4>
          <div style={{ display: "grid", gap: "0.5rem" }}>
            {[
              { label: "Ollama", status: serviceHealth.ollama },
              { label: "LiveKit", status: serviceHealth.livekit },
              { label: "Agent", status: serviceHealth.agent },
            ].map((item) => (
              <div
                key={item.label}
                style={{
                  border: "1px solid #e2e8f0",
                  borderRadius: "8px",
                  padding: "0.55rem 0.7rem",
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                  background: "#ffffff",
                }}
              >
                <span>{item.label}</span>
                <span style={{ color: statusColor(item.status), fontWeight: 700 }}>
                  {item.status.toUpperCase()}
                </span>
              </div>
            ))}
          </div>
        </section>

        <section style={{ display: "grid", gap: "0.8rem" }}>
          <h4 style={{ margin: 0 }}>Model Params</h4>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Model</span>
            <select
              value={settings.model}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  model: event.target.value,
                }))
              }
              style={{ padding: "0.55rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            >
              {modelOptions.map((modelName) => (
                <option key={modelName} value={modelName}>
                  {modelName}
                </option>
              ))}
            </select>
          </label>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Temperature: {settings.temperature.toFixed(2)}</span>
            <input
              type="range"
              min="0"
              max="2"
              step="0.01"
              value={settings.temperature}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  temperature: Number(event.target.value),
                }))
              }
            />
          </label>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Top-P: {settings.top_p.toFixed(2)}</span>
            <input
              type="range"
              min="0"
              max="1"
              step="0.01"
              value={settings.top_p}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  top_p: Number(event.target.value),
                }))
              }
            />
          </label>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Top-K: {settings.top_k}</span>
            <input
              type="range"
              min="0"
              max="100"
              step="1"
              value={settings.top_k}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  top_k: Number(event.target.value),
                }))
              }
            />
          </label>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Max Tokens</span>
            <input
              type="number"
              min={64}
              max={8192}
              step={64}
              value={settings.max_tokens}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  max_tokens: Number(event.target.value),
                }))
              }
              style={{ padding: "0.55rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            />
          </label>

          <label style={{ display: "grid", gap: "0.35rem" }}>
            <span>Language</span>
            <select
              value={settings.language}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  language: event.target.value,
                }))
              }
              style={{ padding: "0.55rem", borderRadius: "8px", border: "1px solid #d1d5db" }}
            >
              <option value="en">EN</option>
              <option value="ru">RU</option>
              <option value="de">DE</option>
              <option value="fr">FR</option>
              <option value="es">ES</option>
            </select>
          </label>

          <label
            style={{
              border: "1px solid #e2e8f0",
              borderRadius: "8px",
              padding: "0.65rem",
              display: "flex",
              alignItems: "center",
              justifyContent: "space-between",
              background: "#ffffff",
            }}
          >
            <span>Thinking Mode</span>
            <input
              type="checkbox"
              checked={settings.reasoning_mode}
              onChange={(event) =>
                setSettings((current) => ({
                  ...current,
                  reasoning_mode: event.target.checked,
                }))
              }
            />
          </label>

          {syncError ? <p style={{ margin: 0, color: "#991b1b" }}>{syncError}</p> : null}
        </section>

        <DisconnectButton>Disconnect</DisconnectButton>
      </aside>
    </div>
  );
}

export default function Home() {
  const [token, setToken] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [connectionStatus, setConnectionStatus] = useState<ConnectionStatus>("idle");
  const [serverUrl, setServerUrl] = useState("");
  const [showSecurityWarning, setShowSecurityWarning] = useState(false);
  const [showInstructions, setShowInstructions] = useState(false);
  const [settings, setSettings] = useState<AgentSettings>({ ...DEFAULT_SETTINGS });
  const [availableModels, setAvailableModels] = useState<string[]>(["<%= modelName %>"]);
  const [serviceHealth, setServiceHealth] = useState<ServiceHealth>({
    ollama: "checking",
    livekit: "offline",
    agent: "offline",
  });
  const [lastAgentHeartbeat, setLastAgentHeartbeat] = useState<number | null>(null);
  const [roomSessionKey, setRoomSessionKey] = useState(0);

  const fallbackModels = useMemo(
    () => ["<%= modelName %>", "qwen3-vl:2b", "qwen3-vl:4b", "llama3.2:3b"],
    []
  );

  const resetSession = useCallback(() => {
    setConnectionStatus("idle");
    setToken(null);
    setError(null);
    setSettings({ ...DEFAULT_SETTINGS });
    setLastAgentHeartbeat(null);
    setRoomSessionKey((current) => current + 1);
    setServiceHealth((current) => ({
      ...current,
      livekit: "offline",
      agent: "offline",
    }));
  }, []);

  useEffect(() => {
    if (typeof window === "undefined") return;

    let envUrl = process.env.NEXT_PUBLIC_LIVEKIT_URL;
    if (!envUrl || envUrl.includes("127.0.0.1") || envUrl.includes("localhost")) {
      const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
      envUrl = `${protocol}//${window.location.hostname}:7880`;
    }
    setServerUrl(envUrl);
    setShowSecurityWarning(!Boolean(window.navigator.mediaDevices?.getUserMedia));
  }, []);

  const requestToken = useCallback(async () => {
    const res = await fetch("/api/token?room=voice-room&username=user");
    if (!res.ok) throw new Error("Failed to fetch token");
    const data = await res.json();
    if (!data.token || typeof data.token !== "string") {
      throw new Error("Token response is invalid");
    }
    return data.token;
  }, []);

  const beginConversation = useCallback(async () => {
    setConnectionStatus("connecting");
    setError(null);
    try {
      const nextToken = await requestToken();
      setToken(nextToken);
      setServiceHealth((current) => ({ ...current, livekit: "checking", agent: "offline" }));
    } catch (err: unknown) {
      setConnectionStatus("error");
      setError(err instanceof Error ? err.message : "Unknown connection error");
    }
  }, [requestToken]);

  useEffect(() => {
    let isCancelled = false;

    async function loadModels() {
      try {
        const res = await fetch("/api/models");
        if (!res.ok) throw new Error("Failed to fetch model list");
        const data = await res.json();
        const models = Array.isArray(data.models)
          ? data.models.filter((item: unknown): item is string => typeof item === "string")
          : [];

        if (!isCancelled && models.length > 0) {
          setAvailableModels(Array.from(new Set([...models, ...fallbackModels])));
          return;
        }
      } catch {
        // Use fallback list.
      }

      if (!isCancelled) {
        setAvailableModels(fallbackModels);
      }
    }

    loadModels();
    return () => {
      isCancelled = true;
    };
  }, [fallbackModels]);

  useEffect(() => {
    setAvailableModels((current) =>
      Array.from(new Set([settings.model, ...current, ...fallbackModels]))
    );
  }, [fallbackModels, settings.model]);

  useEffect(() => {
    if (typeof window === "undefined") return;
    const ollamaUrl = `http://${window.location.hostname}:11434/api/tags`;
    let active = true;

    const checkOllama = async () => {
      setServiceHealth((current) => ({ ...current, ollama: "checking" }));
      try {
        const response = await fetch(ollamaUrl, { cache: "no-store" });
        if (!active) return;
        setServiceHealth((current) => ({
          ...current,
          ollama: response.ok ? "online" : "offline",
        }));
      } catch {
        if (!active) return;
        setServiceHealth((current) => ({ ...current, ollama: "offline" }));
      }
    };

    checkOllama();
    const timer = setInterval(checkOllama, 15000);

    return () => {
      active = false;
      clearInterval(timer);
    };
  }, []);

  useEffect(() => {
    const timer = setInterval(() => {
      const online =
        typeof lastAgentHeartbeat === "number" && Date.now() - lastAgentHeartbeat < 25000;
      setServiceHealth((current) => ({
        ...current,
        agent: online ? "online" : "offline",
      }));
    }, 5000);

    return () => clearInterval(timer);
  }, [lastAgentHeartbeat]);

  const handleRoomStateChange = useCallback((roomState: ConnectionState) => {
    if (roomState === ConnectionState.Connected) {
      setConnectionStatus("connected");
      setServiceHealth((current) => ({ ...current, livekit: "online" }));
      return;
    }
    if (roomState === ConnectionState.Disconnected) {
      setServiceHealth((current) => ({ ...current, livekit: "offline", agent: "offline" }));
      return;
    }
    setConnectionStatus("connecting");
    setServiceHealth((current) => ({ ...current, livekit: "checking" }));
  }, []);

  const handleAgentHeartbeat = useCallback(() => {
    setLastAgentHeartbeat(Date.now());
    setServiceHealth((current) => ({ ...current, agent: "online" }));
  }, []);

  const buttonLabel =
    connectionStatus === "connecting"
      ? "Connecting..."
      : connectionStatus === "error"
        ? "Retry Conversation"
        : "Start Conversation";

  const showActionButton = connectionStatus !== "connected";

  return (
    <main style={{ padding: "2rem", textAlign: "center", maxWidth: "1360px", margin: "0 auto" }}>
      <h1 style={{ marginBottom: "0.5rem" }}><%= projectName %></h1>
      <p style={{ color: "#475569", marginTop: 0 }}>
        Status: <strong>{connectionStatus.toUpperCase()}</strong>
      </p>

      {showSecurityWarning ? (
        <div
          style={{
            background: "#fee2e2",
            border: "1px solid #ef4444",
            color: "#991b1b",
            borderRadius: "10px",
            padding: "0.85rem 1rem",
            marginBottom: "1rem",
            fontWeight: 600,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            gap: "0.75rem",
            textAlign: "left",
          }}
        >
          <span>
            ⚠️ Security Warning: microphone access is blocked because `navigator.mediaDevices` is
            unavailable over insecure remote HTTP.
          </span>
          <button
            type="button"
            onClick={() => setShowInstructions(true)}
            style={{
              borderRadius: "8px",
              border: "1px solid #b91c1c",
              background: "#ffffff",
              color: "#b91c1c",
              padding: "0.4rem 0.75rem",
              fontWeight: 700,
              cursor: "pointer",
              whiteSpace: "nowrap",
            }}
          >
            Instructions
          </button>
        </div>
      ) : null}

      {showInstructions ? (
        <div
          style={{
            position: "fixed",
            inset: 0,
            background: "rgba(15, 23, 42, 0.6)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            zIndex: 1000,
            padding: "1rem",
          }}
          onClick={() => setShowInstructions(false)}
        >
          <div
            style={{
              maxWidth: "640px",
              width: "100%",
              textAlign: "left",
              background: "#ffffff",
              borderRadius: "12px",
              border: "1px solid #e5e7eb",
              padding: "1rem",
            }}
            onClick={(event) => event.stopPropagation()}
          >
            <h3 style={{ marginTop: 0 }}>Remote HTTP Microphone Fix</h3>
            <ol style={{ margin: "0.4rem 0 0 1rem", padding: 0 }}>
              <li>Open `chrome://flags/#unsafely-treat-insecure-origin-as-secure`</li>
              <li>Enable the flag and add your remote origin (e.g. `http://192.168.1.20:3000`)</li>
              <li>Restart Chrome and reload this page</li>
            </ol>
            <p style={{ marginBottom: 0, color: "#475569" }}>
              Prefer HTTPS (or Ngrok) for production deployments.
            </p>
            <button
              type="button"
              onClick={() => setShowInstructions(false)}
              style={{
                marginTop: "1rem",
                borderRadius: "8px",
                border: "1px solid #d1d5db",
                background: "#f8fafc",
                padding: "0.45rem 0.75rem",
                cursor: "pointer",
              }}
            >
              Close
            </button>
          </div>
        </div>
      ) : null}

      {error ? (
        <div
          style={{
            border: "1px solid #fca5a5",
            background: "#fef2f2",
            color: "#991b1b",
            borderRadius: "10px",
            padding: "0.8rem",
            marginBottom: "1rem",
            textAlign: "left",
          }}
        >
          {error}
        </div>
      ) : null}

      {showActionButton ? (
        <button
          type="button"
          onClick={beginConversation}
          disabled={connectionStatus === "connecting" || !serverUrl}
          style={{
            padding: "0.75rem 1.25rem",
            marginBottom: "1rem",
            borderRadius: "10px",
            border: "1px solid #cbd5e1",
            background: "#f8fafc",
            cursor: connectionStatus === "connecting" ? "not-allowed" : "pointer",
          }}
        >
          {buttonLabel}
        </button>
      ) : null}

      {token && serverUrl ? (
        <LiveKitRoom
          key={roomSessionKey}
          serverUrl={serverUrl}
          token={token}
          connect={connectionStatus === "connecting" || connectionStatus === "connected"}
          audio={true}
        >
          <VoiceAssistantUI
            settings={settings}
            setSettings={setSettings}
            availableModels={availableModels}
            serviceHealth={serviceHealth}
            onRoomStateChange={handleRoomStateChange}
            onDisconnected={resetSession}
            onAgentHeartbeat={handleAgentHeartbeat}
          />
          <RoomAudioRenderer />
        </LiveKitRoom>
      ) : (
        <p style={{ color: "#64748b" }}>
          {connectionStatus === "connecting" ? "Preparing secure room token..." : "Ready to connect."}
        </p>
      )}
    </main>
  );
}
