"use client";

import { useEffect, useState } from "react";
import {
  LiveKitRoom,
  RoomAudioRenderer,
  useVoiceAssistant,
  BarVisualizer,
  Chat,
  DisconnectButton,
  useLocalParticipant,
  useConnectionState,
  ConnectionState,
  useRoomContext
} from "@livekit/components-react";
import "@livekit/components-styles";

function VoiceAssistantUI() {
  const room = useRoomContext();
  const { state, audioTrack } = useVoiceAssistant();
  const { localParticipant } = useLocalParticipant();
  const roomState = useConnectionState();

  const [selectedModel, setSelectedModel] = useState("<%= modelName %>");
  const [temperature, setTemperature] = useState(0.7);
  const [topP, setTopP] = useState(0.9);
  const [topK, setTopK] = useState(40);
  const [reasoning, setReasoning] = useState(false);
  
  const [language, setLanguage] = useState("<%= language %>");
  const [sttModel, setSttModel] = useState("base");
  const [showLogs, setShowLogs] = useState(false);
  const [logs, setLogs] = useState<string[]>([]);

  useEffect(() => {
    if (!room) return;
    const handleData = (payload: Uint8Array) => {
      try {
        const msg = new TextDecoder().decode(payload);
        setLogs(prev => [...prev, `[Agent]: ${msg}`]);
      } catch (e) {}
    };
    room.on("data_received", handleData);
    room.on("connected", () => setLogs(prev => [...prev, "[System]: Connected to room"]));
    room.on("disconnected", () => setLogs(prev => [...prev, "[System]: Disconnected"]));
    return () => { room.off("data_received", handleData); };
  }, [room]);

  useEffect(() => {
    if (localParticipant && roomState === ConnectionState.Connected) {
      const timer = setTimeout(() => {
        try {
          const payload = JSON.stringify({ temperature, topP, topK, reasoning, language, sttModel });
          localParticipant.publishData(new TextEncoder().encode(payload), { reliable: true }).catch(() => {});
        } catch (e) {}
      }, 500);
      return () => clearTimeout(timer);
    }
  }, [temperature, topP, topK, reasoning, language, sttModel, localParticipant, roomState]);

  return (
    <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))", gap: "1rem", padding: "1rem 0", textAlign: "left" }}>
      <section style={{ border: "1px solid #e5e7eb", borderRadius: "12px", padding: "1rem", background: "#ffffff" }}>
        <h2 style={{ marginTop: 0, marginBottom: "0.5rem" }}>Voice + Text</h2>
        <p style={{ marginTop: 0, color: "#374151" }}>Agent State: <strong>{state}</strong></p>
        <BarVisualizer state={state} barCount={5} trackRef={audioTrack} style={{ width: "100%", height: "80px" }} />
        <div style={{ marginTop: "1rem", border: "1px solid #e5e7eb", borderRadius: "10px", overflow: "hidden", height: "400px" }}>
          <Chat />
        </div>
      </section>

      <aside style={{ border: "1px solid #e5e7eb", borderRadius: "12px", padding: "1rem", background: "#f8fafc", display: "flex", flexDirection: "column", gap: "1rem" }}>
        <h3 style={{ margin: 0 }}>Control Center</h3>
        
        <div style={{ display: "flex", flexDirection: "column", gap: "0.75rem" }}>
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Language</span>
            <select value={language} onChange={(e) => setLanguage(e.target.value)} style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}>
              <option value="en">English</option>
              <option value="ru">Russian</option>
              <option value="de">German</option>
              <option value="es">Spanish</option>
            </select>
          </label>
          
          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>STT Model (Whisper)</span>
            <select value={sttModel} onChange={(e) => setSttModel(e.target.value)} style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}>
              <option value="base">Base (Fast)</option>
              <option value="small">Small (Accurate)</option>
            </select>
          </label>

          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>LLM Model</span>
            <select value={selectedModel} onChange={(e) => setSelectedModel(e.target.value)} style={{ padding: "0.5rem", borderRadius: "8px", border: "1px solid #d1d5db" }}>
              <option value="<%= modelName %>"><%= modelName %></option>
              <option value="qwen2.5:3b">qwen2.5:3b (Multilingual)</option>
              <option value="llama3.2:3b">llama3.2:3b</option>
            </select>
          </label>

          <label style={{ display: "flex", flexDirection: "column", gap: "0.35rem" }}>
            <span>Temperature: {temperature.toFixed(2)}</span>
            <input type="range" min="0" max="2" step="0.05" value={temperature} onChange={(e) => setTemperature(Number(e.target.value))} />
          </label>
          
          <label style={{ display: "flex", alignItems: "center", gap: "0.5rem", marginTop: "0.5rem" }}>
            <input type="checkbox" checked={reasoning} onChange={(e) => setReasoning(e.target.checked)} style={{ width: "18px", height: "18px" }} />
            <strong>🧠 Reasoning Mode</strong>
          </label>
        </div>

        <div style={{ marginTop: "0.5rem" }}>
          <button onClick={() => setShowLogs(!showLogs)} style={{ width: "100%", padding: "0.5rem", borderRadius: "8px", background: "#e2e8f0", border: "none", cursor: "pointer", fontWeight: "bold" }}>
            {showLogs ? "Hide Logs ▲" : "Show Logs ▼"}
          </button>
          {showLogs && (
            <div style={{ marginTop: "0.5rem", padding: "0.5rem", background: "#1e293b", color: "#10b981", borderRadius: "8px", height: "150px", overflowY: "auto", fontSize: "0.85rem", fontFamily: "monospace", display: "flex", flexDirection: "column", gap: "0.2rem" }}>
              {logs.length === 0 ? <span>Waiting for events...</span> : logs.map((log, i) => <div key={i}>{log}</div>)}
            </div>
          )}
        </div>

        <DisconnectButton>Disconnect</DisconnectButton>
      </aside>
    </div>
  );
}

export default function Home() {
  const [token, setToken] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [connected, setConnected] = useState(false);
  const [serverUrl, setServerUrl] = useState("");

  useEffect(() => {
    if (typeof window !== "undefined") {
      let envUrl = process.env.NEXT_PUBLIC_LIVEKIT_URL;
      if (!envUrl || envUrl.includes("127.0.0.1") || envUrl.includes("localhost")) {
        const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
        envUrl = `${protocol}//${window.location.hostname}:7880`;
      }
      setServerUrl(envUrl);
    }
  }, []);

  useEffect(() => {
    async function fetchToken() {
      try {
        const res = await fetch("/api/token?room=voice-room&username=user");
        if (!res.ok) throw new Error("Failed to fetch token");
        const data = await res.json();
        setToken(data.token);
      } catch (err: unknown) {
        setError(err instanceof Error ? err.message : "Unknown error");
      }
    }
    fetchToken();
  }, []);

  if (error) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        <h1>Error</h1>
        <p>{error}</p>
      </div>
    );
  }

  if (!token) {
    return (
      <div style={{ padding: "2rem", textAlign: "center" }}>
        <p>Connecting to voice agent...</p>
      </div>
    );
  }

  return (
    <main style={{ padding: "2rem", textAlign: "center", maxWidth: "1200px", margin: "0 auto" }}>
      <h1><%= projectName %></h1>
      {!connected && (
        <button
          type="button"
          onClick={() => setConnected(true)}
          disabled={!serverUrl}
          style={{ padding: "0.75rem 1.25rem", marginBottom: "1rem" }}
        >
          Start Conversation
        </button>
      )}
      {serverUrl ? (
        <LiveKitRoom
          serverUrl={serverUrl}
          token={token}
          connect={connected}
          audio={true}
          onDisconnected={() => setConnected(false)}
        >
          <VoiceAssistantUI />
          <RoomAudioRenderer />
        </LiveKitRoom>
      ) : (
        <p>Detecting LiveKit server URL...</p>
      )}
    </main>
  );
}
