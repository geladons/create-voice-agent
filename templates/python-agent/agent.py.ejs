import json
import os
import logging
import urllib.request
import asyncio
import httpx
from livekit.agents import AutoSubscribe, JobContext, WorkerOptions, cli, Agent, AgentSession
from livekit.rtc import DataPacket
from livekit.plugins import silero
from livekit.plugins import openai as openai_plugin
from custom_stt.faster_whisper_stt import FasterWhisperSTT
from custom_tts.piper_tts import PiperTTSPlugin

logger = logging.getLogger("voice-agent")
logger.setLevel(logging.INFO)


async def entrypoint(ctx: JobContext):
    logger.info(f"Connecting to room: {ctx.room.name}")
    await ctx.connect(auto_subscribe=AutoSubscribe.AUDIO_ONLY)
    participant = await ctx.wait_for_participant()
    logger.info(f"Participant joined: {participant.identity}")

    # Use extended timeout (120s) to prevent "Request timed out" on slow CPUs
    http_client = httpx.AsyncClient(timeout=120.0)

    llm = openai_plugin.LLM(
        model="<%= modelName %>",
        base_url=os.environ.get("OLLAMA_BASE_URL", "http://host.docker.internal:11434/v1"),
        api_key="ollama",
        client=http_client,
    )

    voice_map = {"en": "en_US-lessac-medium", "ru": "ru_RU-dmitri-medium", "de": "de_DE-thorsten-medium", "es": "es_ES-carlfm-medium"}
    language = "<%= language %>"
    tts_model = voice_map.get(language, "en_US-lessac-medium")
    onnx_path = f"/app/models/{tts_model}.onnx"
    json_path = f"/app/models/{tts_model}.onnx.json"

    if not os.path.exists(onnx_path):
        os.makedirs("/app/models", exist_ok=True)
        parts = tts_model.split("-")
        lang_dir = parts[0].split("_")[0]
        hf_url = f"https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/{lang_dir}/{parts[0]}/{parts[1]}/{parts[2]}/{tts_model}"
        try:
            logger.info(f"Downloading TTS: {tts_model}...")
            urllib.request.urlretrieve(f"{hf_url}.onnx?download=true", onnx_path)
            urllib.request.urlretrieve(f"{hf_url}.onnx.json?download=true", json_path)
        except Exception as e:
            logger.error(f"Failed to download TTS model: {e}")

    tts_engine = PiperTTSPlugin(model=onnx_path)
    stt_engine = FasterWhisperSTT(model="base", language=language)

    agent = Agent(instructions="You are a helpful, conversational AI. Keep your responses concise.")
    session = AgentSession(vad=silero.VAD.load(), stt=stt_engine, llm=llm, tts=tts_engine)

    @ctx.room.on("data_received")
    def on_data_received(data_packet: DataPacket):
        try:
            payload = json.loads(data_packet.data.decode("utf-8"))
            if "reasoning" in payload:
                agent.instructions = "You are a logical reasoning AI. Think step-by-step before answering." if payload["reasoning"] else "You are a helpful, conversational AI. Keep your responses concise."

            # Send confirmation log back to UI
            msg = f"Settings updated (Lang: {payload.get('language')})"
            asyncio.create_task(ctx.room.local_participant.publish_data(msg.encode("utf-8")))
        except Exception as e:
            pass

    await session.start(agent=agent, room=ctx.room)


if __name__ == "__main__":
    cli.run_app(WorkerOptions(entrypoint_fnc=entrypoint))
