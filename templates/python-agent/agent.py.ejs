async def entrypoint(ctx: JobContext):
    """Called when a participant joins the LiveKit room."""

    logger.info(f"Connecting to room: {ctx.room.name}")
    await ctx.connect(auto_subscribe=AutoSubscribe.AUDIO_ONLY)

    participant = await ctx.wait_for_participant()
    logger.info(f"Participant joined: {participant.identity}")

<% if (llmProvider === 'openai') { -%>
    llm = openai_plugin.LLM(model="gpt-4o-mini")
    tts_engine = openai_plugin.TTS(voice="alloy")
    stt_engine = deepgram.STT()
<% } else { -%>
    settings = {
        "model": "<%= modelName %>",
        "temperature": 0.7,
        "top_p": 0.9,
        "top_k": 40,
        "max_tokens": 512,
        "reasoning_mode": False,
        "language": "<%= language %>",
    }

    ollama_base_url = os.environ.get("OLLAMA_BASE_URL", "http://host.docker.internal:11434")
    await wait_for_ollama(ollama_base_url, timeout_seconds=60)

    llm = create_llm_engine(ollama_base_url, settings)
    stt_engine = FasterWhisperSTT(model="base", language=settings["language"])
    tts_engine = PiperTTSPlugin(model=ensure_piper_voice(settings["language"]))
<% } -%>

    agent = VoicePipelineAgent(
        vad=silero.VAD.load(),
        stt=stt_engine,
        llm=llm,
        tts=tts_engine,
    )

    agent.start(ctx.room, participant)

<% if (llmProvider !== 'openai') { -%>
    _update_reasoning_prompt(agent, settings["reasoning_mode"])

    async def heartbeat_loop() -> None:
        while True:
            await _publish_room_data(
                ctx,
                {
                    "type": "heartbeat",
                    "service": "agent",
                    "status": "online",
                    "timestamp": int(time.time()),
                },
                topic="agent-heartbeat",
                reliable=False,
            )
            await asyncio.sleep(10)

    async def apply_settings_update(payload: bytes) -> None:
        nonlocal llm, tts_engine
        try:
            message = json.loads(payload.decode("utf-8"))
        except (UnicodeDecodeError, json.JSONDecodeError):
            logger.warning("Ignoring invalid settings payload.")
            return

        if not isinstance(message, dict):
            return

        updated = False

        model = message.get("model")
        if isinstance(model, str) and model.strip():
            settings["model"] = model.strip()
            updated = True

        temperature = message.get("temperature")
        if isinstance(temperature, (int, float)):
            settings["temperature"] = max(0.0, min(2.0, float(temperature)))
            updated = True

        top_p = message.get("top_p")
        if isinstance(top_p, (int, float)):
            settings["top_p"] = max(0.0, min(1.0, float(top_p)))
            updated = True

        top_k = message.get("top_k")
        if isinstance(top_k, (int, float)):
            settings["top_k"] = max(0, min(100, int(top_k)))
            updated = True

        max_tokens = message.get("max_tokens")
        if isinstance(max_tokens, (int, float)):
            settings["max_tokens"] = max(64, min(8192, int(max_tokens)))
            updated = True

        reasoning_mode = message.get("reasoning_mode")
        if isinstance(reasoning_mode, bool):
            settings["reasoning_mode"] = reasoning_mode
            updated = True

        language = message.get("language")
        if isinstance(language, str) and language.strip():
            settings["language"] = language.strip().lower()
            updated = True

        if not updated:
            return

        logger.info("Applying updated settings from UI: %s", settings)

        llm = create_llm_engine(ollama_base_url, settings)
        tts_engine = PiperTTSPlugin(
            model=await asyncio.to_thread(ensure_piper_voice, settings["language"])
        )
        stt_engine.language = settings["language"]

        _set_agent_engines(agent, llm, tts_engine, stt_engine)
        _update_reasoning_prompt(agent, settings["reasoning_mode"])

    def handle_data(packet) -> None:
        payload = getattr(packet, "data", packet)
        if isinstance(payload, (bytes, bytearray)):
            asyncio.create_task(apply_settings_update(bytes(payload)))

    try:
        ctx.room.on("data_received", handle_data)
    except TypeError:
        @ctx.room.on("data_received")
        def _decorated_handle_data(packet) -> None:
            handle_data(packet)

    heartbeat_task = asyncio.create_task(heartbeat_loop())
<% } -%>

    try:
        await agent.say("Hello! I'm your voice assistant. How can I help you today?")
        await asyncio.Event().wait()
    finally:
<% if (llmProvider !== 'openai') { -%>
        heartbeat_task.cancel()
        with contextlib.suppress(asyncio.CancelledError):
            await heartbeat_task
<% } -%>
        logger.info("Agent session finished.")


if __name__ == "__main__":
    cli.run_app(WorkerOptions(entrypoint_fnc=entrypoint))
