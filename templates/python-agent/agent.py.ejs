    "en": "en_US-lessac-medium",
    "ru": "ru_RU-dmitri-medium",
    "de": "de_DE-thorsten-medium",
    "fr": "fr_FR-upmc-medium",
    "es": "es_ES-carlfm-medium",
}


def _build_hf_voice_url(voice_name: str) -> str:
    # Example voice_name: en_US-lessac-medium
    language_region, _speaker, quality = voice_name.split("-")
    language = language_region.split("_")[0]
    return (
        f"https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/"
        f"{language}/{language_region}/{quality}/{voice_name}"
    )


def _download_with_retry(url: str, destination: str, retries: int = 4) -> None:
    delay_seconds = 1
    for attempt in range(1, retries + 1):
        try:
            urllib.request.urlretrieve(url, destination)
            return
        except Exception as exc:
            if attempt >= retries:
                raise RuntimeError(f"Failed to download {url} after {retries} attempts") from exc
            logger.warning(
                "Download failed (%s/%s) for %s: %s. Retrying in %ss...",
                attempt,
                retries,
                url,
                exc,
                delay_seconds,
            )
            time.sleep(delay_seconds)
            delay_seconds *= 2


def ensure_piper_voice(language: str) -> str:
    tts_model = VOICE_MAP.get(language, "en_US-lessac-medium")
    onnx_path = f"/app/models/{tts_model}.onnx"
    json_path = f"/app/models/{tts_model}.onnx.json"

    if os.path.exists(onnx_path) and os.path.exists(json_path):
        return onnx_path

    os.makedirs("/app/models", exist_ok=True)
    hf_url = _build_hf_voice_url(tts_model)
    logger.info("Language auto-detected: %s. Ensuring voice model %s...", language, tts_model)

    if not os.path.exists(onnx_path):
        _download_with_retry(f"{hf_url}.onnx?download=true", onnx_path)
    if not os.path.exists(json_path):
        _download_with_retry(f"{hf_url}.onnx.json?download=true", json_path)

    return onnx_path


def _ollama_ready(base_url: str) -> bool:
    try:
        with urllib.request.urlopen(f"{base_url.rstrip('/')}/api/tags", timeout=3) as response:
            return 200 <= response.status < 300
    except (urllib.error.URLError, TimeoutError, OSError):
        return False


async def wait_for_ollama(base_url: str, timeout_seconds: int = 60) -> None:
    logger.info("Waiting for Ollama to become ready at %s...", base_url)
    deadline = time.monotonic() + timeout_seconds

    while time.monotonic() < deadline:
        if await asyncio.to_thread(_ollama_ready, base_url):
            logger.info("Ollama is ready.")
            return
        await asyncio.sleep(2)

    raise RuntimeError(f"Ollama was not ready within {timeout_seconds} seconds at {base_url}")


def create_llm_engine(ollama_base_url: str, settings: dict):
    kwargs = {
        "model": settings["model"],
        "base_url": ollama_base_url,
        "temperature": settings["temperature"],
        "top_p": settings["top_p"],
        "top_k": settings["top_k"],
        "max_tokens": settings["max_tokens"],
    }
    optional_keys = ["max_tokens", "top_k", "top_p", "temperature"]

    while True:
        try:
            return openai_plugin.LLM.with_ollama(**kwargs)
        except TypeError as exc:
            dropped_key = None
            message = str(exc)
            for key in optional_keys:
                if key in kwargs and key in message:
                    dropped_key = key
                    break
            if dropped_key is None:
                for key in optional_keys:
                    if key in kwargs:
                        dropped_key = key
                        break
            if dropped_key is None:
                logger.warning("Falling back to model/base_url only due to API mismatch: %s", exc)
                return openai_plugin.LLM.with_ollama(
                    model=settings["model"],
                    base_url=ollama_base_url,
                )
            logger.warning("LLM setting '%s' is unsupported in this SDK/runtime and was ignored.", dropped_key)
            kwargs.pop(dropped_key, None)


def _set_agent_engines(agent: VoicePipelineAgent, llm_engine, tts_engine, stt_engine) -> None:
    # Keep compatibility with both public and internal attribute names.
    for attr, value in (
        ("llm", llm_engine),
        ("tts", tts_engine),
        ("stt", stt_engine),
        ("_llm", llm_engine),
        ("_tts", tts_engine),
        ("_stt", stt_engine),
    ):
        if hasattr(agent, attr):
            setattr(agent, attr, value)


def _update_reasoning_prompt(agent: VoicePipelineAgent, enabled: bool) -> None:
    chat_ctx = getattr(agent, "chat_ctx", None)
    if chat_ctx is None:
        logger.warning("Agent does not expose chat_ctx; reasoning prompt could not be updated.")
        return

    try:
        messages = getattr(chat_ctx, "messages", None)
        if isinstance(messages, list):
            messages[:] = [
                msg
                for msg in messages
                if REASONING_PROMPT not in str(getattr(msg, "content", ""))
            ]

        if not enabled:
            return

        if hasattr(chat_ctx, "append"):
            try:
                chat_ctx.append(role="system", text=REASONING_PROMPT)
                return
            except TypeError:
                pass

        if hasattr(chat_ctx, "add_message"):
            try:
                chat_ctx.add_message(role="system", content=REASONING_PROMPT)
                return
            except TypeError:
                pass

        if isinstance(messages, list):
            try:
                from livekit.agents.llm import ChatMessage

                messages.append(ChatMessage(role="system", content=REASONING_PROMPT))
            except Exception as exc:
                logger.warning("Failed to append reasoning prompt to chat context: %s", exc)
    except Exception as exc:
        logger.warning("Failed to update reasoning prompt state: %s", exc)


async def _publish_room_data(ctx: JobContext, payload: dict, topic: str, reliable: bool = False) -> None:
    data = json.dumps(payload).encode("utf-8")
    publisher = getattr(ctx.room.local_participant, "publish_data", None)
    if publisher is None:
        return

    try:
        result = publisher(data, reliable=reliable, topic=topic)
    except TypeError:
        try:
            result = publisher(data, reliable)
        except TypeError:
            result = publisher(data)

    if asyncio.iscoroutine(result):
        await result
