"""
<%= projectName %> — Voice AI Agent
Uses the official livekit-agents library with VoicePipelineAgent.
"""

import json
import os
import logging
import urllib.request

from livekit.agents import AutoSubscribe, JobContext, WorkerOptions, cli
from livekit.agents.llm import ChatContext, ChatMessage
from livekit.agents.pipeline import VoicePipelineAgent
from livekit.plugins import silero
from livekit.rtc import DataPacket
<% if (llmProvider === 'openai') { -%>
from livekit.plugins import deepgram
from livekit.plugins import openai as openai_plugin
<% } else { -%>
from livekit.plugins import openai as openai_plugin
from custom_stt.faster_whisper_stt import FasterWhisperSTT
from custom_tts.piper_tts import PiperTTSPlugin
<% } -%>

logger = logging.getLogger("voice-agent")
logger.setLevel(logging.INFO)


async def entrypoint(ctx: JobContext):
    """Called when a participant joins the LiveKit room."""

    logger.info(f"Connecting to room: {ctx.room.name}")
    await ctx.connect(auto_subscribe=AutoSubscribe.AUDIO_ONLY)

    participant = await ctx.wait_for_participant()
    logger.info(f"Participant joined: {participant.identity}")

<% if (llmProvider === 'openai') { -%>
    llm = openai_plugin.LLM(model="gpt-4o-mini")
    tts_engine = openai_plugin.TTS(voice="alloy")
    stt_engine = deepgram.STT()
<% } else { -%>
    llm = openai_plugin.LLM.with_ollama(
        model="<%= modelName %>",
        base_url=os.environ.get("OLLAMA_BASE_URL", "http://host.docker.internal:11434"),
    )

    voice_map = {
        "en": "en_US-lessac-medium",
        "ru": "ru_RU-dmitri-medium",
        "de": "de_DE-thorsten-medium",
        "fr": "fr_FR-upmc-medium",
        "es": "es_ES-carlfm-medium",
    }
    language = "<%= language %>"
    tts_model = voice_map.get(language, "en_US-lessac-medium")
    onnx_path = f"/app/models/{tts_model}.onnx"
    json_path = f"/app/models/{tts_model}.onnx.json"

    if not os.path.exists(onnx_path):
        os.makedirs("/app/models", exist_ok=True)
        logger.info(f"Language auto-detected: {language}. Downloading {tts_model}...")
        hf_url = f"https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/{tts_model.split('-')[0]}/{tts_model.split('-')[0]}_{tts_model.split('-')[1]}/{tts_model.split('-')[2]}/{tts_model}"
        urllib.request.urlretrieve(f"{hf_url}.onnx?download=true", onnx_path)
        urllib.request.urlretrieve(f"{hf_url}.onnx.json?download=true", json_path)

    tts_engine = PiperTTSPlugin(model=onnx_path)
    stt_engine = FasterWhisperSTT(model="base", language=language)
<% } -%>

    initial_ctx = ChatContext(
        messages=[
            ChatMessage(
                role="system",
                content="You are a helpful, conversational AI. Keep your responses concise and natural.",
            )
        ]
    )

    agent = VoicePipelineAgent(
        vad=silero.VAD.load(),
        stt=stt_engine,
        llm=llm,
        tts=tts_engine,
        chat_ctx=initial_ctx,
    )

    agent.start(ctx.room, participant)

    @ctx.room.on("data_received")
    def on_data_received(data_packet: DataPacket):
        try:
            payload = json.loads(data_packet.data.decode("utf-8"))
            logger.info(f"Received UI settings update: {payload}")
            if "reasoning" in payload:
                sys_msg = agent.chat_ctx.messages[0]
                if payload["reasoning"]:
                    sys_msg.content = "You are a highly logical reasoning AI. Think step-by-step before answering. Keep your spoken output natural but explain your logic."
                    logger.info("Switched to Reasoning Mode.")
                else:
                    sys_msg.content = "You are a helpful, conversational AI. Keep your responses concise and natural."
                    logger.info("Switched to Standard Mode.")
        except Exception as e:
            logger.error(f"Error handling UI data: {e}")

    await agent.say("Hello! I'm online. How can I help you today?")


if __name__ == "__main__":
    cli.run_app(WorkerOptions(entrypoint_fnc=entrypoint))
