logger = logging.getLogger("voice-agent")
logger.setLevel(logging.INFO)
CHAT_TOPIC = "lk.chat"
LANGUAGE_NAMES = {
    "en": "English",
    "ru": "Russian",
    "de": "German",
    "fr": "French",
    "es": "Spanish",
}


def _env_float(name: str, default: float) -> float:
    raw = os.getenv(name)
    if raw is None:
        return default

    try:
        value = float(raw)
    except ValueError:
        logger.warning("Invalid %s=%r, falling back to %.1f", name, raw, default)
        return default

    if value < 0:
        logger.warning("%s must be non-negative, falling back to %.1f", name, default)
        return default

    return value


def _env_int(name: str, default: int, minimum: int = 1) -> int:
    raw = os.getenv(name)
    if raw is None:
        return default

    try:
        value = int(raw)
    except ValueError:
        logger.warning("Invalid %s=%r, falling back to %d", name, raw, default)
        return default

    if value < minimum:
        logger.warning("%s must be >= %d, falling back to %d", name, minimum, default)
        return default

    return value


def _normalize_language(language_code: str) -> str:
    normalized = (language_code or "").strip().lower()
    if normalized in LANGUAGE_NAMES:
        return normalized
    if "-" in normalized:
        short = normalized.split("-", 1)[0]
        if short in LANGUAGE_NAMES:
            return short
    return "en"


def _clamp_float(value, minimum: float, maximum: float, default: float) -> float:
    try:
        parsed = float(value)
    except (TypeError, ValueError):
        return default
    return max(minimum, min(parsed, maximum))


def _clamp_int(value, minimum: int, maximum: int, default: int) -> int:
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        return default
    return max(minimum, min(parsed, maximum))


def _build_agent_instructions(reasoning: bool, language: str) -> str:
    target_language = LANGUAGE_NAMES.get(language, "English")
    style = (
        "Reason step-by-step before answering, but provide only the final concise answer unless asked for details."
        if reasoning
        else "Keep responses concise and practical."
    )
    return (
        f"You are a helpful real-time voice assistant. {style} "
        f"Always respond in {target_language}."
    )


async def _publish_ui_log(ctx: JobContext, message: str) -> None:
    try:
        await ctx.room.local_participant.publish_data(message.encode("utf-8"))
    except Exception as exc:
        logger.debug("Failed to publish UI log: %s", exc)


async def _publish_chat_message(ctx: JobContext, text: str) -> None:
    message = text.strip()
    if not message:
        return

    try:
        await ctx.room.local_participant.send_text(message, topic=CHAT_TOPIC)
    except Exception as exc:
        logger.debug("Failed to publish chat message: %s", exc)


def _extract_text_content(item: object) -> str:
    text_content = getattr(item, "text_content", None)
    if isinstance(text_content, str):
        return text_content.strip()

    content = getattr(item, "content", None)
    if not isinstance(content, list):
        return ""

    parts: list[str] = []
    for part in content:
        if isinstance(part, str):
            stripped = part.strip()
            if stripped:
                parts.append(stripped)
    return "\n".join(parts)


<% if (llmProvider === 'ollama') { -%>
VOICE_MODEL_BY_LANGUAGE = {
    "en": "en_US-lessac-medium",
    "ru": "ru_RU-dmitri-medium",
    "de": "de_DE-thorsten-medium",
    "fr": "fr_FR-upmc-medium",
    "es": "es_ES-carlfm-medium",
}


def _build_piper_url(tts_model: str) -> str:
    parts = tts_model.split("-")
    if len(parts) != 3:
        raise ValueError(f"Unsupported Piper model format: {tts_model}")

    lang_dir = parts[0].split("_")[0]
    return f"https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/{lang_dir}/{parts[0]}/{parts[1]}/{parts[2]}/{tts_model}"


def _ensure_piper_voice_model(tts_model: str) -> str:
    onnx_path = f"/app/models/{tts_model}.onnx"
    json_path = f"/app/models/{tts_model}.onnx.json"
    if os.path.exists(onnx_path):
        return onnx_path

    os.makedirs("/app/models", exist_ok=True)
    hf_url = _build_piper_url(tts_model)
    logger.info("Downloading Piper voice: %s", tts_model)
    urllib.request.urlretrieve(f"{hf_url}.onnx?download=true", onnx_path)
    urllib.request.urlretrieve(f"{hf_url}.onnx.json?download=true", json_path)
    logger.info("Piper voice downloaded: %s", tts_model)
    return onnx_path


def _apply_ollama_runtime_settings(llm, settings: dict) -> None:
    opts = getattr(llm, "_opts", None)
    if opts is None:
        return

    opts.model = settings["model"]
    opts.temperature = settings["temperature"]
    opts.top_p = settings["topP"]
    opts.extra_body = {"options": {"top_k": settings["topK"]}}


async def _warmup_ollama_model(client: openai.AsyncOpenAI, model_name: str) -> None:
    try:
        await client.chat.completions.create(
            model=model_name,
            messages=[{"role": "system", "content": "Warmup"}],
            max_tokens=1,
        )
        logger.info("Ollama warmup completed for model: %s", model_name)
    except Exception as exc:
        logger.debug("Ollama warmup skipped/failed for %s: %s", model_name, exc)
<% } -%>


async def entrypoint(ctx: JobContext):
    logger.info("Connecting to room: %s", ctx.room.name)
    await ctx.connect(auto_subscribe=AutoSubscribe.AUDIO_ONLY)

    participant = await ctx.wait_for_participant()
    logger.info("Participant joined: %s", participant.identity)

    settings = {
        "temperature": 0.4,
        "topP": 0.9,
        "topK": 40,
        "reasoning": False,
        "language": _normalize_language("<%= language %>"),
<% if (llmProvider === 'openai') { -%>
        "model": os.getenv("OPENAI_MODEL", "gpt-4o-mini"),
<% } else { -%>
        "model": "<%= modelName %>",
        "sttModel": os.getenv("FASTER_WHISPER_MODEL", "base"),
<% } -%>
    }

    oai_client = None

<% if (llmProvider === 'openai') { -%>
    llm = openai_plugin.LLM(model=settings["model"])
    tts_engine = openai_plugin.TTS(voice="alloy")
    stt_engine = deepgram.STT()
<% } else { -%>
    import httpx
    llm_timeout_sec = _env_float("OLLAMA_LLM_TIMEOUT_SEC", 120.0)

    # Keep a long timeout so Ollama has enough time to load model weights.
    oai_client = openai.AsyncOpenAI(
        api_key="ollama",
        base_url=os.environ.get("OLLAMA_BASE_URL", "http://host.docker.internal:11434/v1"),
        max_retries=0,
        http_client=httpx.AsyncClient(
            timeout=httpx.Timeout(llm_timeout_sec),
            follow_redirects=True,
        ),
    )

    # Pass the correctly formatted client to LiveKit
    llm = openai_plugin.LLM(
        model=settings["model"],
        client=oai_client
    )
    _apply_ollama_runtime_settings(llm, settings)

    tts_model = VOICE_MODEL_BY_LANGUAGE.get(settings["language"], "en_US-lessac-medium")
    piper_ort_intra_threads = _env_int("PIPER_ORT_INTRA_THREADS", 1)
    piper_ort_inter_threads = _env_int("PIPER_ORT_INTER_THREADS", 1)

    try:
        onnx_path = _ensure_piper_voice_model(tts_model)
    except Exception as exc:
        logger.warning("Failed to prepare Piper voice %s: %s. Falling back to English.", tts_model, exc)
        settings["language"] = "en"
        onnx_path = _ensure_piper_voice_model("en_US-lessac-medium")

    tts_engine = PiperTTSPlugin(
        model=onnx_path,
        ort_intra_threads=piper_ort_intra_threads,
        ort_inter_threads=piper_ort_inter_threads,
    )
    stt_engine = FasterWhisperSTT(
        model=settings["sttModel"],
        language=settings["language"],
    )
    warmup_enabled = str(os.getenv("OLLAMA_WARMUP", "1")).strip().lower() in {"1", "true", "yes", "on"}
    if warmup_enabled:
        asyncio.create_task(_warmup_ollama_model(oai_client, settings["model"]))
<% } -%>

    agent = Agent(
        instructions=_build_agent_instructions(settings["reasoning"], settings["language"])
    )
    session = AgentSession(
        vad=silero.VAD.load(),
        stt=stt_engine,
        llm=llm,
        tts=tts_engine,
    )

    @session.on("user_input_transcribed")
    def on_user_input_transcribed(ev):
        if not getattr(ev, "is_final", False):
            return
        transcript = (getattr(ev, "transcript", "") or "").strip()
        if transcript:
            asyncio.create_task(_publish_chat_message(ctx, transcript))

    @session.on("conversation_item_added")
    def on_conversation_item_added(ev):
        item = getattr(ev, "item", None)
        if getattr(item, "role", None) != "assistant":
            return
        response_text = _extract_text_content(item)
        if response_text:
            asyncio.create_task(_publish_chat_message(ctx, response_text))

    room_disconnected = asyncio.Event()

    @ctx.room.on("disconnected")
    def on_room_disconnected(reason):
        logger.info("Room disconnected: %s", reason)
        room_disconnected.set()

    @ctx.room.on("data_received")
    def on_data_received(data_packet: DataPacket):
        try:
            payload = json.loads(data_packet.data.decode("utf-8"))
            if not isinstance(payload, dict):
                raise ValueError("payload must be a JSON object")

            prev_language = settings["language"]
            prev_model = settings["model"]
<% if (llmProvider === 'ollama') { -%>
            prev_stt_model = settings["sttModel"]
<% } -%>

            if "reasoning" in payload:
                settings["reasoning"] = bool(payload["reasoning"])
            if "temperature" in payload:
                settings["temperature"] = _clamp_float(payload["temperature"], 0.0, 2.0, settings["temperature"])
            if "topP" in payload:
                settings["topP"] = _clamp_float(payload["topP"], 0.0, 1.0, settings["topP"])
            if "topK" in payload:
                settings["topK"] = _clamp_int(payload["topK"], 1, 200, settings["topK"])
            if "language" in payload and isinstance(payload["language"], str):
                settings["language"] = _normalize_language(payload["language"])
            if "model" in payload and isinstance(payload["model"], str):
                candidate_model = payload["model"].strip()
                if candidate_model:
                    settings["model"] = candidate_model
<% if (llmProvider === 'ollama') { -%>
            if "sttModel" in payload and isinstance(payload["sttModel"], str):
                candidate_stt_model = payload["sttModel"].strip()
                if candidate_stt_model:
                    settings["sttModel"] = candidate_stt_model
<% } -%>

<% if (llmProvider === 'ollama') { -%>
            _apply_ollama_runtime_settings(llm, settings)
<% } -%>
            if settings["language"] != prev_language:
<% if (llmProvider === 'ollama') { -%>
                stt_engine.set_language(settings["language"])
                tts_model = VOICE_MODEL_BY_LANGUAGE.get(settings["language"], "en_US-lessac-medium")
                try:
                    onnx_path = _ensure_piper_voice_model(tts_model)
                    tts_engine.set_model(onnx_path)
                except Exception as exc:
                    logger.warning("Failed to switch TTS language to %s: %s", settings["language"], exc)
                    settings["language"] = "en"
                    fallback_path = _ensure_piper_voice_model("en_US-lessac-medium")
                    tts_engine.set_model(fallback_path)
<% } else { -%>
                logger.info("Language changed to %s (STT/TTS provider constraints apply)", settings["language"])
<% } -%>

<% if (llmProvider === 'ollama') { -%>
            if settings["sttModel"] != prev_stt_model:
                try:
                    stt_engine.set_model(settings["sttModel"])
                except Exception as exc:
                    logger.warning("Failed to switch STT model to %s: %s", settings["sttModel"], exc)
                    settings["sttModel"] = prev_stt_model
<% } -%>

            asyncio.create_task(
                agent.update_instructions(
                    _build_agent_instructions(settings["reasoning"], settings["language"])
                )
            )

<% if (llmProvider === 'ollama') { -%>
            if settings["model"] != prev_model and warmup_enabled:
                asyncio.create_task(_warmup_ollama_model(oai_client, settings["model"]))
<% } -%>

            msg = (
                f"Settings applied (reasoning={settings['reasoning']}, "
                f"model={settings['model']}, "
                f"temp={settings['temperature']:.2f}, "
                f"top_p={settings['topP']:.2f}, "
                f"top_k={settings['topK']}, "
                f"lang={settings['language']}"
<% if (llmProvider === 'ollama') { -%>
                f", stt={settings['sttModel']}"
<% } -%>
                f")"
            )
            asyncio.create_task(_publish_ui_log(ctx, msg))
        except Exception as exc:
            logger.warning("Error handling UI settings update: %s", exc)
            asyncio.create_task(_publish_ui_log(ctx, f"Settings update rejected: {exc}"))

    try:
        await session.start(agent=agent, room=ctx.room)
        if ctx.room.isconnected():
            await room_disconnected.wait()
    finally:
        await session.aclose()
        if oai_client is not None:
            await oai_client.close()


if __name__ == "__main__":
    cli.run_app(
        WorkerOptions(
            entrypoint_fnc=entrypoint,
            job_memory_warn_mb=_env_float("LIVEKIT_JOB_MEMORY_WARN_MB", 1024.0),
            job_memory_limit_mb=_env_float("LIVEKIT_JOB_MEMORY_LIMIT_MB", 1536.0),
        )
    )
